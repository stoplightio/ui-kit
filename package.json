{
  "name": "@stoplight/ui-kit",
  "version": "3.0.3",
  "description": "Foundational React components for the Stoplight ecosystem. Stable version with all critical security vulnerabilities patched.",
  "keywords": [
    "react",
    "ui",
    "ui-components",
    "secure",
    "stable"
  ],
  "main": "index.js",
  "types": "index.d.ts",
  "sideEffects": false,
  "homepage": "https://github.com/stoplightio/ui-kit",
  "bugs": "https://github.com/stoplightio/ui-kit/issues",
  "author": "Stoplight <support@stoplight.io>",
  "repository": {
    "type": "git",
    "url": "https://github.com/stoplightio/ui-kit.git"
  },
  "license": "Apache-2.0",
  "files": [
    "**/*"
  ],
  "scripts": {
    "build": "sl-scripts build --sourcemap && yarn build.styles",
    "build.styles": "yarn build.tw && copyfiles -u 1 \"./src/styles/**/*\" ./dist",
    "build.tw": "postcss ./scripts/build-tailwind/tailwind.css -o ./src/styles/tailwind/_base.scss -c ./sripts/tailwind-build/postcss.config.js",
    "commit": "git-cz",
    "lint": "yarn prettier.check && eslint --ext .js,.jsx,.ts,.tsx .",
    "lint.fix": "prettier --ignore-path .eslintignore --write '**/*.{js,jsx,ts,tsx,graphql,md}'; eslint --ext .js,.jsx,.ts,.tsx . --fix",
    "prettier.check": "prettier --ignore-path .eslintignore --check '**/*.{js,jsx,ts,tsx,md}'",
    "release": "sl-scripts release",
    "release.dryRun": "sl-scripts release --dry-run --debug",
    "storybook": "start-storybook -p 9001",
    "test": "jest",
    "type-check": "tsc --noEmit",
    "test.prod": "yarn lint && yarn type-check && yarn test --runInBand",
    "test.update": "yarn test --updateSnapshot",
    "test.watch": "yarn test --watch"
  },
  "peerDependencies": {
    "react": ">=16.8",
    "react-dom": ">=16.8"
  },
  "dependencies": {
    "@blueprintjs/core": "^3.29.0",
    "@blueprintjs/icons": "^3.19.0",
    "@blueprintjs/select": "^3.13.4",
    "@fortawesome/fontawesome-common-types": "^0.2.31",
    "classnames": "^2.2.6",
    "prismjs": "^1.27.0",
    "react-input-autosize": "^2.2.2",
    "react-scrollbars-custom": "~4.0.25",
    "react-simple-code-editor": "~0.11.0",
    "react-tabs": "^3.1.1",
    "react-virtualized-auto-sizer": "^1.0.2",
    "react-window": "~1.8.5",
    "refractor": "^3.0.0",
    "tslib": "^1.12.0",
    "use-debounce": "^3.4.3",
    "yup": "^0.28.3"
  },
  "devDependencies": {
    "@babel/core": "^7.9",
    "@sambego/storybook-state": "^1.3",
    "@stoplight/eslint-config": "^1.1.0",
    "@stoplight/json": "^3.6.0",
    "@stoplight/scripts": "^8.2.0",
    "@stoplight/storybook-config": "2.0.5",
    "@storybook/addon-actions": "^5.3.18",
    "@storybook/addon-info": "^5.3.18",
    "@storybook/addon-knobs": "^5.3.18",
    "@storybook/addon-links": "^5.3.18",
    "@storybook/addon-options": "^5.3.18",
    "@storybook/addons": "^5.3.18",
    "@storybook/core": "^5.3.18",
    "@storybook/react": "^5.3.18",
    "@storybook/theming": "^5.3.18",
    "@types/classnames": "^2.2.10",
    "@types/enzyme": "^3.10.5",
    "@types/enzyme-adapter-react-16": "^1.0.6",
    "@types/jest": "^25.2.1",
    "@types/lodash": "^4.14.149",
    "@types/node-sass": "^4.11.0",
    "@types/prettier": "^2.0.0",
    "@types/prismjs": "^1.16.0",
    "@types/react": "~16.9.34",
    "@types/react-dom": "~16.9.6",
    "@types/react-input-autosize": "^2.0.2",
    "@types/react-tabs": "^2.3.1",
    "@types/react-virtualized-auto-sizer": "^1.0.0",
    "@types/react-window": "^1.8.1",
    "@types/refractor": "^2.8.0",
    "@types/yup": "~0.26.35",
    "@typescript-eslint/eslint-plugin": "^2.27.0",
    "@typescript-eslint/parser": "^2.27.0",
    "autoprefixer": "^9.7.6",
    "babel-loader": "^8.1.0",
    "copyfiles": "^2.2.0",
    "css-loader": "^3.5.2",
    "enzyme": "^3.11.0",
    "enzyme-adapter-react-16": "^1.15.2",
    "enzyme-to-json": "^3.4.4",
    "eslint": "^6.8.0",
    "eslint-plugin-import": "^2.20.2",
    "eslint-plugin-jest": "^23.8.2",
    "eslint-plugin-prettier": "^3.1.2",
    "eslint-plugin-react": "^7.19.0",
    "eslint-plugin-react-hooks": "^3.0.0",
    "eslint-plugin-simple-import-sort": "^5.0.2",
    "jest": "^25.3.0",
    "jest-enzyme": "^7.1.2",
    "lodash": "^4.17.15",
    "node-sass": "^4.13.1",
    "postcss-cli": "^7.1.0",
    "postcss-import": "^12.0.1",
    "prettier": "~2.0.4",
    "react": "~16.12.0",
    "react-dom": "~16.12.0",
    "resolve-url-loader": "^3.1.1",
    "sass-inline-svg": "^1.2.3",
    "sass-loader": "^8.0.2",
    "tailwindcss": "~1.3.0",
    "ts-jest": "^25.3.1",
    "ts-loader": "^6.2.2",
    "typescript": "3.8.3",
    "webpack": "~4.42.1"
  },
  "resolutions": {
    "qs": "6.14.1",
    "telejson": "6.0.0",
    "tmp": "0.2.4",
    "elliptic": "6.6.1",
    "shell-quote": "1.7.3",
    "form-data": "2.5.4",
    "cross-spawn": "6.0.6",
    "semver": "5.7.2",
    "js-yaml": "3.14.2",
    "minimist": "1.2.8",
    "tough-cookie": "4.1.3",
    "property-expr": "2.0.6",
    "merge-deep": "3.0.3",
    "handlebars": "4.7.9",
    "url-parse": "1.5.10",
    "pbkdf2": "3.1.3",
    "sha.js": "2.4.12",
    "cipher-base": "1.0.5",
    "eventsource": "1.1.1",
    "ejs": "3.1.7",
    "json-schema": "0.4.0",
    "loader-utils": "1.4.2",
    "@babel/traverse": "7.23.2",
    "axios": "1.15.0",
    "acorn": "7.4.0",
    "markdown-to-jsx": "^6.11.4",
    "prismjs": "1.27.0",
    "y18n": "3.2.2",
    "ws": "5.2.4",
    "follow-redirects": "1.14.7",
    "@storybook/addon-actions/axios": "0.30.3",
    "tar": "7.5.11",
    "terser": "4.8.1",
    "semver-regex": "3.1.3",
    "ssri": "6.0.2",
    "decode-uri-component": "0.2.1",
    "ansi-regex": "^5.0.1",
    "semantic-release": "17.2.3",
    "marked": "4.0.10",
    "trim-newlines": "^3.0.1",
    "glob-parent": "5.1.2",
    "glob": "7.2.3",
    "micromatch": "4.0.8",
    "minimatch": "3.1.4",
    "http-cache-semantics": "4.1.1",
    "npm-user-validate": "1.0.1",
    "websocket-extensions": "0.1.4",
    "merge": "2.1.1",
    "braces": "3.0.3",
    "shelljs": "0.8.5",
    "ua-parser-js": "0.7.24",
    "nested-object-assign": "1.0.4",
    "ini": "1.3.8",
    "object-path": "0.11.8",
    "node-fetch": "2.6.7",
    "tmpl": "1.0.5",
    "nth-check": "2.0.1",
    "body-parser": "1.20.3",
    "path-to-regexp": "0.1.13",
    "ansi-html": "0.0.8",
    "cookie": "^0.7.0",
    "serialize-javascript": "7.0.3",
    "rollup": "2.80.0",
    "dot-prop": "^4.2.1",
    "@storybook/addon-actions/highlight.js": "10.4.1",
    "webpack-dev-middleware": "5.3.4",
    "json5": "2.2.2",
    "flatted": "3.4.2",
    "normalize-url": "5.3.1",
    "browserify-sign": "4.2.2"

  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix"
    ]
  },
  "husky": {
    "hooks": {
      "commit-msg": "commitlint -E HUSKY_GIT_PARAMS",
      "pre-commit": "lint-staged"
    }
  },
  "config": {
    "commitizen": {
      "path": "node_modules/cz-conventional-changelog"
    }
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "release": {
    "extends": "@stoplight/scripts/release"
  }
}
